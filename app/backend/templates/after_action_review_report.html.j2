<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>After Action Review {{ review.id }}</title>
  <style>
    body { font-family: "Segoe UI", sans-serif; margin: 2rem; color: #1f2933; background: #f7fafc; }
    h1, h2 { color: #102a43; }
    .card { background: white; border: 1px solid #d9e2ec; border-radius: 12px; padding: 1rem 1.25rem; margin-bottom: 1rem; }
    table { width: 100%; border-collapse: collapse; }
    th, td { border-bottom: 1px solid #e6edf3; padding: 0.55rem; text-align: left; }
    th { background: #f0f4f8; }
    code { background: #eef2f7; padding: 0.1rem 0.3rem; border-radius: 4px; }
  </style>
</head>
<body>
  <h1>After Action Review</h1>
  <div class="card">
    <p><strong>Review ID:</strong> {{ review.id }}</p>
    <p><strong>Run ID:</strong> {{ review.run_id }}</p>
    <p><strong>Plan ID:</strong> {{ review.plan_id }}</p>
    <p><strong>Comparison ID:</strong> {{ review.comparison_id }}</p>
  </div>

  <div class="card">
    <h2>Outcome Summary</h2>
    <p><strong>Status:</strong> {{ review.summary_json.actual_outcome.status }}</p>
    <p><strong>Mission timeline:</strong> {{ review.summary_json.mission_timeline }}</p>
  </div>

  <div class="card">
    <h2>Feasibility and Confidence</h2>
    <p>{{ review.summary_json.feasibility_summary.operator_summary if review.summary_json.feasibility_summary else "No launch-feasibility summary was captured." }}</p>
    <p>{{ review.summary_json.confidence_summary.confidence_reason if review.summary_json.confidence_summary else "No recommendation-confidence note was captured." }}</p>
  </div>

  <div class="card">
    <h2>Mission Area Review</h2>
    <p>{{ mission_area.operator_summary or "Mission area summary not recorded." }}</p>
    {% if mission_area.terrain_summary %}
    <p>{{ mission_area.terrain_summary.operator_summary }}</p>
    {% endif %}
    <table>
      <tbody>
        <tr><th>Location</th><td>{{ mission_area.location_display_name or "n/a" }}</td></tr>
        <tr><th>Area size</th><td>{{ mission_area.area_sq_km or "n/a" }} km²</td></tr>
        <tr><th>Grid resolution</th><td>{{ mission_area.grid_resolution_m or "n/a" }} m</td></tr>
        <tr><th>Grid size</th><td>{% if mission_area.grid_size %}{{ mission_area.grid_size[0] }} x {{ mission_area.grid_size[1] }}{% else %}n/a{% endif %}</td></tr>
        <tr><th>Staging</th><td>{{ mission_area.staging.label if mission_area.staging else "n/a" }}</td></tr>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>Search Pattern Review</h2>
    <p><strong>Pattern:</strong> {{ search_pattern.pattern_label or "Not recorded" }}</p>
    <p>{{ search_pattern.summary or "Pattern summary not recorded." }}</p>
    <p>{{ search_pattern.reason or "Pattern fit note not recorded." }}</p>
    <p>{{ search_pattern.mission_effect_summary or "No pattern-change note recorded." }}</p>
  </div>

  <div class="card">
    <h2>Deviation From Recommendation</h2>
    <p>{{ review.summary_json.deviation_summary or "No deviation summary was captured for this review." }}</p>
    {% if review.summary_json.deviation_from_recommendation %}
    <table>
      <tbody>
        {% for key, value in review.summary_json.deviation_from_recommendation.items() %}
        <tr><th>{{ key|replace("_", " ")|title }}</th><td>{{ value }}</td></tr>
        {% endfor %}
      </tbody>
    </table>
    {% endif %}
  </div>

  <div class="card">
    <h2>Battery Lifecycle Review</h2>
    <p><strong>Run phase:</strong> {{ review.summary_json.battery_lifecycle.run_phase }}</p>
    <p><strong>Reserve policy:</strong> {{ review.summary_json.battery_lifecycle.reserve_preset|replace("_", " ")|title }}</p>
    <p>{{ review.summary_json.battery_lifecycle.asset_utilization_summary }}</p>
    <p>{{ review.summary_json.battery_lifecycle.mission_continuity_impact }}</p>
    <table>
      <thead><tr><th>Measure</th><th>Value</th></tr></thead>
      <tbody>
        <tr><td>Returns to base</td><td>{{ review.summary_json.battery_lifecycle.return_to_base_count }}</td></tr>
        <tr><td>Recharge or swap started</td><td>{{ review.summary_json.battery_lifecycle.recharge_started_count }}</td></tr>
        <tr><td>Recharge or swap completed</td><td>{{ review.summary_json.battery_lifecycle.recharge_completed_count }}</td></tr>
        <tr><td>Redeployments</td><td>{{ review.summary_json.battery_lifecycle.redeploy_count }}</td></tr>
        <tr><td>Rejoins</td><td>{{ review.summary_json.battery_lifecycle.rejoin_count }}</td></tr>
        <tr><td>Coverage gaps</td><td>{{ review.summary_json.battery_lifecycle.coverage_gap_count }}</td></tr>
      </tbody>
    </table>
    <p>
      <strong>Battery margin:</strong>
      Min {{ review.summary_json.battery_lifecycle.battery_margin_summary.minimum_margin }}
      / Avg {{ review.summary_json.battery_lifecycle.battery_margin_summary.average_margin }}
    </p>
    <p>{{ review.summary_json.battery_lifecycle.battery_margin_summary.sustainability }}</p>
  </div>

  <div class="card">
    <h2>Sensing Workflow Review</h2>
    <p>{{ review.summary_json.sensing_lifecycle.operator_summary }}</p>
    <p>{{ review.summary_json.sensing_lifecycle.inspection_burden_summary }}</p>
    <p>{{ review.summary_json.sensing_lifecycle.mission_impact_summary }}</p>
    <table>
      <thead><tr><th>Measure</th><th>Value</th></tr></thead>
      <tbody>
        <tr><td>Possible contacts</td><td>{{ review.summary_json.sensing_lifecycle.candidate_detection_count }}</td></tr>
        <tr><td>Inspections started</td><td>{{ review.summary_json.sensing_lifecycle.inspection_initiated_count }}</td></tr>
        <tr><td>Inspection passes</td><td>{{ review.summary_json.sensing_lifecycle.inspection_pass_count }}</td></tr>
        <tr><td>Confirmed contacts</td><td>{{ review.summary_json.sensing_lifecycle.confirmed_detection_count }}</td></tr>
        <tr><td>Rejected false alarms</td><td>{{ review.summary_json.sensing_lifecycle.false_positive_count }}</td></tr>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>Alternate Plan Analysis</h2>
    <p>{{ review.alternate_plan_json.summary if review.alternate_plan_json else "No alternate-plan analysis was captured for this review." }}</p>
  </div>

  <div class="card">
    <h2>Technical Appendix</h2>
    <p>{{ review.summary_json.assumptions_summary or review.summary_json.provenance_manifest.assumptions_summary or "Assumptions summary not recorded." }}</p>
    <p>{{ review.summary_json.known_limitations_summary or review.summary_json.provenance_manifest.known_limitations_summary or "Known limitations summary not recorded." }}</p>
    <table>
      <tbody>
        <tr><th>Model version</th><td>{{ review.summary_json.provenance_manifest.model_version or "n/a" }}</td></tr>
        <tr><th>Scenario version</th><td>{{ review.summary_json.provenance_manifest.scenario_version or "n/a" }}</td></tr>
        <tr><th>Calibration version</th><td>{{ review.summary_json.provenance_manifest.calibration_version or "n/a" }}</td></tr>
        <tr><th>Deployment mode</th><td>{{ review.summary_json.provenance_manifest.deployment_mode or "n/a" }}</td></tr>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>Timeline</h2>
    <table>
      <thead><tr><th>Step</th><th>Event</th><th>Summary</th></tr></thead>
      <tbody>
      {% for event in review.timeline_json.key_events %}
        <tr><td>{{ event.step }}</td><td>{{ event.event_type }}</td><td>{{ event.summary or event.details }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>Structured Appendix</h2>
    <code>{{ review.summary_json }}</code>
  </div>
</body>
</html>
