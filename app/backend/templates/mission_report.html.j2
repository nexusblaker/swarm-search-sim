<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Mission Report {{ run.run_id }}</title>
  <style>
    body { font-family: "Segoe UI", sans-serif; margin: 2rem; color: #1f2933; background: #f7fafc; }
    h1, h2 { color: #102a43; }
    .card { background: white; border: 1px solid #d9e2ec; border-radius: 12px; padding: 1rem 1.25rem; margin-bottom: 1rem; }
    table { width: 100%; border-collapse: collapse; }
    th, td { border-bottom: 1px solid #e6edf3; padding: 0.55rem; text-align: left; }
    th { background: #f0f4f8; }
    code { background: #eef2f7; padding: 0.1rem 0.3rem; border-radius: 4px; }
  </style>
</head>
<body>
  <h1>Mission Summary Report</h1>
  <div class="card">
    <p><strong>Run ID:</strong> {{ run.run_id }}</p>
    <p><strong>Scenario:</strong> {{ run.scenario_id }}</p>
    <p><strong>Status:</strong> {{ run.status }}</p>
    <p><strong>Strategy:</strong> {{ run.summary.strategy }}</p>
    <p><strong>Scenario Family:</strong> {{ run.summary.scenario_family }}</p>
    <p><strong>Target Behavior:</strong> {{ run.summary.target_behavior }}</p>
  </div>

  <div class="card">
    <h2>Metrics</h2>
    <table>
      <thead><tr><th>Metric</th><th>Value</th></tr></thead>
      <tbody>
      {% for name, value in metrics.items() %}
        <tr><td>{{ name }}</td><td>{{ value }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>Key Event Summary</h2>
    <table>
      <thead><tr><th>Event Type</th><th>Count</th></tr></thead>
      <tbody>
      {% for name, value in event_counts.items() %}
        <tr><td>{{ name }}</td><td>{{ value }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>Artifact References</h2>
    <ul>
      {% for name, path in artifacts.items() %}
      <li><strong>{{ name }}</strong>: <code>{{ path }}</code></li>
      {% endfor %}
    </ul>
  </div>

  <div class="card">
    <h2>Detection Timeline / Event Samples</h2>
    <table>
      <thead><tr><th>Step</th><th>Type</th><th>Payload</th></tr></thead>
      <tbody>
      {% for event in events %}
        <tr><td>{{ event.step }}</td><td>{{ event.event_type }}</td><td><code>{{ event }}</code></td></tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</body>
</html>
